{
  "schema_version": 1,
  "id": "wave3-mosaic-cube-alma-large-width1024-dirty-probe-auto",
  "mode_id": "mosaic-cube-one-channel",
  "description": "Wave 3 #284 full-width initial dirty/PSF probe using the large ALMA mosaic MS, all seven fields, specmode=cube nchan=1 width=1024, uniform weighting, full 1280 image geometry, and auto acceleration defaults.",
  "dataset": {
    "key": "wave1-alma-mosaic-large",
    "relative_path": "wave1/alma/mosaic-large/large/ms/wave1-alma-mosaic-large.ms",
    "root_env": "CASA_RS_IMPERF_DATA_ROOT"
  },
  "imaging": {
    "mode": "dirty",
    "specmode": "cube",
    "gridder": "mosaic",
    "wterm": "none",
    "field": "0,1,2,3,4,5,6",
    "phasecenter_field": 0,
    "spw": "0",
    "channel_start": 0,
    "channel_count": 1,
    "start": "0",
    "width": "1024",
    "interpolation": "nearest",
    "imsize": 1280,
    "cell_arcsec": 0.08,
    "weighting": "uniform",
    "robust": 0.5,
    "perchanweightdensity": true,
    "deconvolver": "clark",
    "hogbom_iteration_mode": "casa",
    "nterms": 1,
    "niter": 0,
    "minor_cycle_length": 1000,
    "pblimit": 0.2,
    "write_pb": true,
    "pbcor": true,
    "standard_mfs_acceleration": "auto"
  },
  "run": {
    "repeats": 1,
    "run_label": "wave3-mosaic-cube-large-width1024-dirty-probe-auto",
    "storage_label": "external-ssd-wave1-large",
    "ms_staging": "direct",
    "skip_casa": "1",
    "skip_profile": "1",
    "phase_probe": "0",
    "evidence_role": "full_width_initial_dirty_probe_auto",
    "stream_log": true,
    "env": {
      "CASA_RS_IMAGING_PROGRESS": "1"
    }
  },
  "comparison": {
    "products": [
      ".image",
      ".residual",
      ".psf",
      ".weight",
      ".sumwt",
      ".pb",
      ".image.pbcor"
    ],
    "max_elements_per_product": 1000000
  }
}

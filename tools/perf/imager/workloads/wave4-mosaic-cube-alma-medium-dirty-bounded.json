{
  "schema_version": 1,
  "id": "wave4-mosaic-cube-alma-medium-dirty-bounded",
  "mode_id": "mosaic-cube-bounded",
  "description": "Wave 4 W4-12 PB-aware mosaic dirty cube medium-output workload using the large ALMA mosaic superset because no separate medium ALMA mosaic MS is registered.",
  "dataset": {
    "key": "wave1-alma-mosaic-large",
    "root_env": "CASA_RS_IMPERF_DATA_ROOT",
    "relative_path": "wave1/alma/mosaic-large/large/ms/wave1-alma-mosaic-large.ms"
  },
  "imaging": {
    "mode": "dirty",
    "specmode": "cube",
    "gridder": "mosaic",
    "interpolation": "nearest",
    "field": "0,1,2,3,4,5,6",
    "phasecenter_field": 0,
    "spw": "0",
    "channel_start": 0,
    "channel_count": 8,
    "start": "0",
    "width": "1",
    "imsize": 2048,
    "cell_arcsec": 0.08,
    "weighting": "natural",
    "robust": 0.5,
    "perchanweightdensity": true,
    "deconvolver": "hogbom",
    "nterms": 1,
    "scales": "",
    "niter": 0,
    "minor_cycle_length": 2,
    "pblimit": 0.2,
    "write_pb": true,
    "pbcor": true,
    "wterm": "none"
  },
  "run": {
    "repeats": 1,
    "run_label": "w4-12-medium-bounded",
    "storage_label": "external-ssd-wave1-large-medium-output",
    "ms_staging": "direct",
    "skip_casa": "1",
    "skip_profile": "1",
    "stream_log": true,
    "env": {
      "CASA_RS_IMAGING_PROGRESS": "1"
    }
  },
  "comparison": {
    "products": [
      ".image",
      ".residual",
      ".psf",
      ".sumwt",
      ".weight",
      ".pb",
      ".image.pbcor"
    ],
    "max_elements_per_product": 1000000
  }
}

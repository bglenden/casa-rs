{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BrowserRequestEnvelope",
  "description": "JSON Lines request envelope sent from `casars` to the browser backend.",
  "type": "object",
  "required": [
    "command",
    "version"
  ],
  "properties": {
    "command": {
      "description": "Requested command.",
      "allOf": [
        {
          "$ref": "#/definitions/BrowserCommand"
        }
      ]
    },
    "version": {
      "description": "Protocol version expected by the client.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "BrowserBookmark": {
      "description": "Stable startup address independent of a rendered viewport.",
      "oneOf": [
        {
          "description": "A cell addressed by zero-based row and column name.",
          "type": "object",
          "required": [
            "column",
            "kind",
            "row"
          ],
          "properties": {
            "column": {
              "description": "Stable column name.",
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "cell"
              ]
            },
            "row": {
              "description": "Zero-based row index.",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            }
          }
        },
        {
          "description": "A table keyword path.",
          "type": "object",
          "required": [
            "kind",
            "path"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "table_keyword"
              ]
            },
            "path": {
              "description": "Keyword-name path from the table keyword root.",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        {
          "description": "A keyword path owned by one column.",
          "type": "object",
          "required": [
            "column",
            "kind",
            "path"
          ],
          "properties": {
            "column": {
              "description": "Owning column name.",
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "column_keyword"
              ]
            },
            "path": {
              "description": "Keyword-name path from the column keyword root.",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        {
          "description": "A linked subtable entry selected by stable name/path/source text.",
          "type": "object",
          "required": [
            "kind",
            "name"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "subtable"
              ]
            },
            "name": {
              "description": "Linked-table selector.",
              "type": "string"
            }
          }
        }
      ]
    },
    "BrowserCommand": {
      "description": "Command sent to the browser backend.",
      "oneOf": [
        {
          "description": "Open the root table for a new or existing session.",
          "type": "object",
          "required": [
            "command",
            "path",
            "viewport"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "open_root"
              ]
            },
            "path": {
              "description": "Filesystem path to the root table.",
              "type": "string"
            },
            "viewport": {
              "description": "Current render viewport.",
              "allOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                }
              ]
            }
          }
        },
        {
          "description": "Apply the durable startup/update parameters to the opened table.",
          "type": "object",
          "required": [
            "command",
            "parameters"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "configure"
              ]
            },
            "parameters": {
              "$ref": "#/definitions/BrowserParameters"
            }
          }
        },
        {
          "description": "Update the render viewport without changing selection state.",
          "type": "object",
          "required": [
            "command",
            "viewport"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "resize"
              ]
            },
            "viewport": {
              "description": "Current render viewport.",
              "allOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                }
              ]
            }
          }
        },
        {
          "description": "Rotate between top-level browser views.",
          "type": "object",
          "required": [
            "command",
            "forward"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "cycle_view"
              ]
            },
            "forward": {
              "description": "`true` for next view, `false` for previous view.",
              "type": "boolean"
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Set the active browser focus pane without changing the current view.",
          "type": "object",
          "required": [
            "command",
            "focus"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "set_focus"
              ]
            },
            "focus": {
              "description": "Focus target within the browser workspace.",
              "allOf": [
                {
                  "$ref": "#/definitions/BrowserFocus"
                }
              ]
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Move the active selection one or more steps upward.",
          "type": "object",
          "required": [
            "command",
            "steps"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "move_up"
              ]
            },
            "steps": {
              "description": "Number of steps to move.",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Move the active selection one or more steps downward.",
          "type": "object",
          "required": [
            "command",
            "steps"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "move_down"
              ]
            },
            "steps": {
              "description": "Number of steps to move.",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Move the active selection or page left.",
          "type": "object",
          "required": [
            "command",
            "steps"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "move_left"
              ]
            },
            "steps": {
              "description": "Number of steps to move.",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Move the active selection or page right.",
          "type": "object",
          "required": [
            "command",
            "steps"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "move_right"
              ]
            },
            "steps": {
              "description": "Number of steps to move.",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Move by one or more pages upward.",
          "type": "object",
          "required": [
            "command",
            "pages"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "page_up"
              ]
            },
            "pages": {
              "description": "Number of pages to move.",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Move by one or more pages downward.",
          "type": "object",
          "required": [
            "command",
            "pages"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "page_down"
              ]
            },
            "pages": {
              "description": "Number of pages to move.",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Activate the selected item or expand the selected inspector node.",
          "type": "object",
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "activate"
              ]
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Pop back to the parent table, if any.",
          "type": "object",
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "back"
              ]
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Collapse one inspector level or return focus to the main pane.",
          "type": "object",
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "escape"
              ]
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "description": "Request the current snapshot without changing state.",
          "type": "object",
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "string",
              "enum": [
                "get_snapshot"
              ]
            },
            "viewport": {
              "description": "Optional viewport update applied before rendering.",
              "anyOf": [
                {
                  "$ref": "#/definitions/BrowserViewport"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        }
      ]
    },
    "BrowserContentMode": {
      "description": "Requested verbosity for rendered table-browser content.",
      "oneOf": [
        {
          "description": "Let the backend choose the representation appropriate to the view.",
          "type": "string",
          "enum": [
            "auto"
          ]
        },
        {
          "description": "Prefer compact one-line values and summaries.",
          "type": "string",
          "enum": [
            "compact"
          ]
        },
        {
          "description": "Prefer expanded details and an inspector-oriented presentation.",
          "type": "string",
          "enum": [
            "detailed"
          ]
        }
      ]
    },
    "BrowserFocus": {
      "description": "Active focus target inside the browser.",
      "oneOf": [
        {
          "description": "Navigation is acting on the main view selection.",
          "type": "string",
          "enum": [
            "main"
          ]
        },
        {
          "description": "Navigation is acting on the inspector selection.",
          "type": "string",
          "enum": [
            "inspector"
          ]
        }
      ]
    },
    "BrowserParameters": {
      "description": "Durable table-browser parameters applied after a root table is open.",
      "type": "object",
      "required": [
        "row_count",
        "row_start",
        "view"
      ],
      "properties": {
        "bookmark": {
          "description": "Optional stable selection restored after opening the target table.",
          "anyOf": [
            {
              "$ref": "#/definitions/BrowserBookmark"
            },
            {
              "type": "null"
            }
          ]
        },
        "content_mode": {
          "description": "Requested content verbosity.",
          "default": "auto",
          "allOf": [
            {
              "$ref": "#/definitions/BrowserContentMode"
            }
          ]
        },
        "linked_table": {
          "description": "Optional linked table to open before applying the view/bookmark.",
          "type": [
            "string",
            "null"
          ]
        },
        "row_count": {
          "description": "Maximum number of rows in the navigable cell window.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "row_start": {
          "description": "First zero-based row in the navigable cell window.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "view": {
          "description": "Initial top-level view.",
          "allOf": [
            {
              "$ref": "#/definitions/BrowserView"
            }
          ]
        }
      }
    },
    "BrowserView": {
      "description": "Top-level browser view.",
      "oneOf": [
        {
          "description": "Table summary and storage metadata.",
          "type": "string",
          "enum": [
            "overview"
          ]
        },
        {
          "description": "Column inventory and per-column metadata.",
          "type": "string",
          "enum": [
            "columns"
          ]
        },
        {
          "description": "Table and column keyword tree.",
          "type": "string",
          "enum": [
            "keywords"
          ]
        },
        {
          "description": "Row/column cell grid.",
          "type": "string",
          "enum": [
            "cells"
          ]
        },
        {
          "description": "Linked persistent subtables.",
          "type": "string",
          "enum": [
            "subtables"
          ]
        }
      ]
    },
    "BrowserViewport": {
      "description": "Render viewport requested by the consumer.",
      "type": "object",
      "required": [
        "height",
        "width"
      ],
      "properties": {
        "height": {
          "description": "Available content height in terminal cells.",
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "inspector_height": {
          "description": "Available inspector height in terminal cells when the client renders the inspector in a separate pane.",
          "default": 0,
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "width": {
          "description": "Available content width in terminal cells.",
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        }
      }
    }
  }
}

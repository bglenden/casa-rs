{
  "schema_version": 1,
  "id": "wave3-aw-widefield-medium-auto",
  "mode_id": "aw-style-widefield-single-plane",
  "description": "Wave 3 #281 AW/widefield alias auto-default row on the generated 33 GiB VLA B L-band wide-field MS, all 512 channels, 4096 image, Briggs, niter=100.",
  "dataset": {
    "key": "wave3-vla-aw-widefield-medium",
    "relative_path": "wave3/vla/aw-widefield/medium/ms/wave3-vla-aw-widefield-medium.ms",
    "root_env": "CASA_RS_IMPERF_DATA_ROOT"
  },
  "imaging": {
    "mode": "clean",
    "specmode": "mfs",
    "gridder": "awproject",
    "casa_gridder": "wproject",
    "wterm": "wproject",
    "wprojplanes": 16,
    "field": "0",
    "spw": "0",
    "channel_start": 0,
    "channel_count": 512,
    "imsize": 4096,
    "cell_arcsec": 0.8,
    "weighting": "briggs",
    "robust": 0.5,
    "deconvolver": "hogbom",
    "hogbom_iteration_mode": "casa",
    "nterms": 1,
    "niter": 100,
    "gain": 0.1,
    "threshold_jy": 0.0,
    "minor_cycle_length": 50,
    "standard_mfs_acceleration": "auto"
  },
  "run": {
    "repeats": 1,
    "run_label": "wave3-aw-widefield-auto-default",
    "storage_label": "external-ssd-wave3-medium",
    "ms_staging": "direct",
    "phase_probe": "0",
    "evidence_role": "auto_default"
  },
  "review": {
    "required_reviewer": "Brian",
    "requires_human_acceptance_before_done": true,
    "required_evidence_roles": [
      "before_baseline",
      "after_multi_worker_cpu",
      "after_gpu_metal",
      "casa_cpp"
    ]
  },
  "comparison": {
    "products": [
      ".image",
      ".residual",
      ".model",
      ".psf"
    ],
    "max_elements_per_product": 1000000
  }
}

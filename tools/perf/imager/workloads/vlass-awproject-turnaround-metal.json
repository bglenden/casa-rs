{
  "schema_version": 1,
  "id": "vlass-awproject-turnaround-metal",
  "mode_id": "vlass-awproject-mtmfs-turnaround-metal-f64",
  "description": "Reduced four-SPW, two-field EVLA AWProject MT-MFS Metal turnaround workload derived from CASA regression data. It exercises compensated Metal gridding with an f64 RustFFT finish but is never final frozen 12,150-pixel correctness or 10x evidence.",
  "dataset": {
    "key": "vlass-awproject-turnaround-v1",
    "relative_path": "vlass-turnaround.ms",
    "root_env": "CASA_RS_VLASS_TURNAROUND_ROOT"
  },
  "imaging": {
    "mode": "dirty",
    "specmode": "mfs",
    "gridder": "awproject",
    "casa_gridder": "awproject",
    "wterm": "wproject",
    "wprojplanes": 32,
    "field": "0,1",
    "phasecenter_field": 0,
    "spw": "0~3",
    "channel_start": 0,
    "channel_count": 3,
    "imsize": 1024,
    "cell_arcsec": 10.0,
    "datacolumn": "data",
    "stokes": "I",
    "projection": "SIN",
    "interpolation": "linear",
    "uvrange": "<12km",
    "intent": "OBSERVE_TARGET#UNSPECIFIED",
    "weighting": "briggs",
    "robust": 1.0,
    "perchanweightdensity": true,
    "deconvolver": "mtmfs",
    "nterms": 2,
    "scales": [0, 5, 12],
    "smallscalebias": 0.0,
    "niter": 0,
    "gain": 0.1,
    "threshold_jy": 0.0,
    "nsigma": 5.0,
    "minor_cycle_length": 2000,
    "cyclefactor": 3.0,
    "min_psf_fraction": 0.05,
    "max_psf_fraction": 0.8,
    "facets": 1,
    "psfphasecenter": "",
    "chanchunks": 1,
    "vptable": "",
    "mosweight": false,
    "aterm": true,
    "psterm": false,
    "wbawp": true,
    "conjbeams": true,
    "usepointing": true,
    "computepastep": 360.0,
    "rotatepastep": 360.0,
    "pointingoffsetsigdev": 0.0,
    "pblimit": 0.0001,
    "normtype": "flatnoise",
    "write_pb": true,
    "pbcor": false,
    "restoration": true,
    "restoringbeam": "common",
    "interactive": false,
    "usemask": "user",
    "restart": false,
    "savemodel": "none",
    "calcres": true,
    "calcpsf": true,
    "parallel": true,
    "standard_mfs_acceleration": "metal",
    "standard_mfs_grid_threads": 1,
    "imaging_fft_precision": "f64",
    "imaging_fft_backend": "rustfft",
    "cfcache": "vlass-turnaround.cf",
    "cf_resident_mb": 256
  },
  "run": {
    "repeats": 3,
    "warmups": 1,
    "profile_repeats": 3,
    "run_label": "vlass-awproject-turnaround-metal-f64-warm",
    "storage_label": "developer-local-turnaround",
    "ms_staging": "direct",
    "cf_cache_role": "warm",
    "evidence_role": "reduced_turnaround_only"
  },
  "comparison": {
    "mode": "full",
    "products": [
      ".alpha",
      ".alpha.error",
      ".image.tt0",
      ".image.tt1",
      ".model.tt0",
      ".model.tt1",
      ".pb.tt0",
      ".psf.tt0",
      ".psf.tt1",
      ".psf.tt2",
      ".residual.tt0",
      ".residual.tt1",
      ".sumwt.tt0",
      ".sumwt.tt1",
      ".sumwt.tt2",
      ".weight.tt0",
      ".weight.tt1",
      ".weight.tt2"
    ],
    "max_elements_per_product": 1000000,
    "full_chunk_elements": 262144,
    "require_exact_product_inventory": true,
    "require_metadata_parity": true,
    "tolerances": {
      "contract_version": 1,
      "require_full_array": true,
      "default": {
        "diff_abs_max_over_right_peak": 0.005,
        "diff_rms_over_right_rms": 0.001,
        "allowed_structure_labels": ["good"]
      },
      "products": {
        ".model.tt0": {
          "allowed_structure_labels": ["good", "not_applicable_exact_zero"]
        },
        ".model.tt1": {
          "allowed_structure_labels": ["good", "not_applicable_exact_zero"]
        }
      }
    }
  }
}

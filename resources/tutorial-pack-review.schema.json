{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bglenden.github.io/casa-rs/schemas/tutorial-pack-review.v0.schema.json",
  "title": "casa-rs Tutorial Pack Section Review v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "tutorial_id",
    "section_id",
    "status",
    "casa_source",
    "casars_equivalents",
    "observable_products",
    "regression_evidence",
    "human_evaluation"
  ],
  "properties": {
    "schema_version": {
      "const": "tutorial-pack-review.v0"
    },
    "pack_id": {
      "$ref": "#/$defs/slash_id"
    },
    "tutorial_id": {
      "$ref": "#/$defs/slash_id"
    },
    "section_id": {
      "$ref": "#/$defs/slash_id"
    },
    "status": {
      "enum": [
        "pending-human-review",
        "accepted",
        "needs-revision",
        "product-gap"
      ]
    },
    "casa_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guide_url",
        "section_anchor",
        "task_calls",
        "expected_observable_result"
      ],
      "properties": {
        "guide_url": {
          "$ref": "#/$defs/http_url"
        },
        "section_anchor": {
          "type": "string",
          "minLength": 1
        },
        "task_calls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task_call"
          }
        },
        "expected_observable_result": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "casars_equivalents": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli",
        "python",
        "tui",
        "gui"
      ],
      "properties": {
        "cli": {
          "$ref": "#/$defs/surface_equivalent"
        },
        "python": {
          "$ref": "#/$defs/surface_equivalent"
        },
        "tui": {
          "$ref": "#/$defs/surface_equivalent"
        },
        "gui": {
          "$ref": "#/$defs/surface_equivalent"
        }
      }
    },
    "observable_products": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "casa_refs",
        "casars_refs",
        "comparison_refs",
        "timing_refs"
      ],
      "properties": {
        "casa_refs": {
          "$ref": "#/$defs/path_refs"
        },
        "casars_refs": {
          "$ref": "#/$defs/path_refs"
        },
        "comparison_refs": {
          "$ref": "#/$defs/path_refs"
        },
        "timing_refs": {
          "$ref": "#/$defs/path_refs"
        }
      }
    },
    "regression_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_manifest_refs",
        "native_run_refs",
        "oracle_run_refs",
        "provider_provenance_refs",
        "screenshot_spec_refs"
      ],
      "properties": {
        "input_manifest_refs": {
          "$ref": "#/$defs/path_refs"
        },
        "native_run_refs": {
          "$ref": "#/$defs/path_refs"
        },
        "oracle_run_refs": {
          "$ref": "#/$defs/path_refs"
        },
        "provider_provenance_refs": {
          "$ref": "#/$defs/path_refs"
        },
        "screenshot_spec_refs": {
          "$ref": "#/$defs/path_refs"
        }
      }
    },
    "human_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "reviewed_by",
        "reviewed_at",
        "comments",
        "required_changes",
        "follow_up_issue_refs"
      ],
      "properties": {
        "outcome": {
          "enum": [
            "pending",
            "accepted",
            "needs-revision",
            "product-gap"
          ]
        },
        "reviewed_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "comments": {
          "type": "string"
        },
        "required_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "follow_up_issue_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "slash_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9._/-]*[a-z0-9]$"
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^(~|/|[A-Za-z]:|.*\\.\\./)"
      }
    },
    "http_url": {
      "type": "string",
      "pattern": "^https://"
    },
    "task_call": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "parameters"
      ],
      "properties": {
        "task_id": {
          "$ref": "#/$defs/slash_id"
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "surface_equivalent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_kind",
        "task_id",
        "parameters"
      ],
      "properties": {
        "provider_kind": {
          "const": "native-rust"
        },
        "task_id": {
          "$ref": "#/$defs/slash_id"
        },
        "parameters": {
          "type": "object"
        },
        "command_template": {
          "type": "string"
        },
        "ui_path": {
          "type": "string"
        },
        "screenshot_refs": {
          "$ref": "#/$defs/path_refs"
        }
      }
    },
    "path_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relative_path"
      }
    }
  }
}
